# =============================================
# IEDNavigator - .gitignore
# =============================================

# Clases compiladas y JARs de salida
classes/
target/
dist/
*.class

# JARs: excluir todo excepto los de lib/ (dependencias pre-empaquetadas)
*.jar
!lib/*.jar

# Backups y ZIPs
*.zip
*.rar
BACKUP_*.zip
ied_navigator_installer.zip

# Versiones antiguas y copias
IEDNavigator_completo/
REFACTORED_SIN_NATIVE/
SIN SMV - copia/
SIN SMV - copia (2)/
installer/output/
installer/download_cache/

# Binarios y ejecutables de terceros
*.exe
*.dll
!lib/*.dll
*.lnk
PcapDotNet.Core.dll

# Carpeta de requisitos (archivos muy pesados)
requisistos ied_navigator/

# Logs y temporales
*.log
*.txt
!README.txt
MMS_log_file.txt
SIN SMV/log*/

# Carpetas personales / terceros
SIN SMV/curso nari_cids_ultimo_proyecto/
SIN SMV/IEDNavigator_Informe_2026-04-23/
SIN SMV/PROMPT_PRESENTACION_Y_PAPERS.md

# CIDs de equipos de fabricantes (potencialmente propietarios)
# Solo se incluye test_smoke.cid (genérico, creado por el proyecto)
SIN SMV/CID/*.cid
SIN SMV/CID/*.CID
SIN SMV/CID/*.icd
SIN SMV/CID/*.ICD
SIN SMV/CID/*.scd
SIN SMV/CID/*.SCD
!SIN SMV/CID/test_smoke.cid

# JNA versión antigua eliminada
lib/jna-5.13.0.jar

# Documentos personales internos
Revision_2 (Parcial).docx
Revision_2 (Parcial).pdf
Wavewin ABB/

# Proyectos Android (repos separados)
android-ied-navigator/
android-ion7400-simulator/
android_ied_simulator - que mejor salio v3.02/

# Versiones antiguas empaquetadas
IEDNavigator_v*/
IEDNavigator.jar
IEDNavigator_new.jar

# HarmonicMonitor (repo separado)
HarmonicMonitor/

# Claude AI internal
.claude/

# IDEs
.idea/
*.iml
.vscode/
*.swp
